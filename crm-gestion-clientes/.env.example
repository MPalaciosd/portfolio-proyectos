# ============================================================
# CONFIGURACIÓN DE EMAIL — CRM-ASIR
# Copiar a .env y rellenar con valores reales.
# NUNCA subir .env a git.
# ============================================================

# ── SMTP ────────────────────────────────────────────────────
# Gmail:      smtp.gmail.com       puerto 587 (STARTTLS)
# Outlook:    smtp.office365.com   puerto 587 (STARTTLS)
# Yahoo:      smtp.mail.yahoo.com  puerto 587 (STARTTLS)
# Propio:     tu-servidor.com      puerto 587 / 465 (SSL)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com

# Gmail: usar "Contraseña de aplicación" (no la contraseña normal)
# Ajustes Google > Seguridad > Verificación en 2 pasos > Contraseñas de app
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Nombre que verá el destinatario en el campo "De:"
SMTP_FROM_NAME=TechSoluciones S.L.

# Dirección de respuesta (puede ser distinta al usuario SMTP)
SMTP_REPLY_TO=soporte@techsoluciones.es

# ── COMPORTAMIENTO ───────────────────────────────────────────
# En modo test, los emails NO se envían — solo se loguean
EMAIL_TEST_MODE=false

# Reintentos automáticos si falla el envío (0 = sin reintento)
EMAIL_RETRY_ATTEMPTS=3

# Segundos entre reintentos
EMAIL_RETRY_DELAY=5
